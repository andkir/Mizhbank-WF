{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "HistoryDb": "Data Source=rates_history.db"
  },
  "ApiUrls": {
    "KursInterbankUsd":   "https://kurs.com.ua/ajax/getChart?type=interbank&currency_from=USD&currency_to=&size=big",
    "KursInterbankEur":   "https://kurs.com.ua/ajax/getChart?type=interbank&currency_from=EUR&currency_to=&size=big",
    "KursBlackMarketUsd": "https://kurs.com.ua/ajax/getChart?type=blackmarket&currency_from=USD&currency_to=&size=small",
    "KursBlackMarketEur": "https://kurs.com.ua/ajax/getChart?type=blackmarket&currency_from=EUR&currency_to=&size=small",
    "KursForexEurUsd":    "https://kurs.com.ua/ajax/getChart?type=forex&currency_from=EUR&currency_to=USD&size=big",

    "KursBankRatesAjax":       "https://kurs.com.ua/ajax/organizations/cash?currency_from={0}&currency_to=undef&organizations=MAJOR&show_optimal=1&current_page=money.index",
    "KursBankRatesAjaxLegacy": "https://kurs.com.ua/ajax/organizations/cash?currency_to=undefined&organizations=MAJOR&show_optimal=1&current_page=money.index&currency_from={0}",

    "KursHome":          "https://kurs.com.ua/",
    "KursBankRatesPage": "https://kurs.com.ua/money.index",
    "KursChartReferer":  "https://kurs.com.ua/mezhbank",

    "FinanceUaDaily": "https://charts.finance.ua/ua/currency/data-daily?for=interbank&source=1&indicator=usd"
  }
}
